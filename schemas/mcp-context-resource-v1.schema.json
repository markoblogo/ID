{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://id-protocol.dev/schemas/mcp-context-resource-v1.schema.json",
  "title": "ID MCP Context Resource v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "resource_version",
    "owner_id",
    "uri",
    "name",
    "description",
    "mime_type",
    "contents",
    "policy"
  ],
  "properties": {
    "resource_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner_id": {
      "type": "string",
      "minLength": 1
    },
    "uri": {
      "type": "string",
      "pattern": "^id://.+/context\\.compact$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "mime_type": {
      "type": "string",
      "const": "application/json"
    },
    "contents": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "applied",
        "task_class",
        "source"
      ],
      "properties": {
        "applied": {
          "type": "boolean"
        },
        "task_class": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  }
}
