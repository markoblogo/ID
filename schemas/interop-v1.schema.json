{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://id-protocol.local/schemas/interop-v1.schema.json",
  "title": "ID Protocol Interop v1",
  "type": "object",
  "required": ["interop_version", "owner_id", "generated_at", "profiles"],
  "properties": {
    "interop_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "owner_id": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "format": "date"},
    "profiles": {
      "type": "object",
      "required": ["core", "extended"],
      "properties": {
        "core": {"type": "object"},
        "extended": {"type": "object"}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
